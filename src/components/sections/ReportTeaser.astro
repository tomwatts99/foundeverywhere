---
/**
 * ReportTeaser.astro: teal promo band for the free AI visibility report.
 *
 * Full-width teal #0C7B82. Two columns on desktop - copy on the left,
 * an anonymised mini report-preview card on the right - stacked on mobile.
 */

// 72px ring → r = 32, circumference ≈ 201.06; arc filled to 58%.
const RING_CIRC = 2 * Math.PI * 32;
const RING_OFFSET = RING_CIRC * (1 - 0.58);
---

<section class="rt" aria-labelledby="rt-title">
  <div class="container rt__inner">
    <div class="rt__copy">
      <p class="rt__eyebrow">Free in minutes</p>
      <h2 id="rt-title" class="rt__title">Find out your AI visibility score</h2>
      <p class="rt__lead">
        We test your business across ChatGPT, Perplexity, and Claude. Free, instant,
        no commitment.
      </p>
    </div>

    <div class="rt__preview">
      <div class="rt-card">
        <!-- Card header -->
        <div class="rt-card__top" aria-hidden="true">
          <span class="rt-card__kicker">AI Visibility Report</span>
          <span class="rt-card__domain">foundeverywhere.co.uk</span>
        </div>

        <!-- Score ring -->
        <div class="rt-card__ring" aria-hidden="true">
          <svg class="rt-card__ring-svg" viewBox="0 0 72 72">
            <circle class="rt-card__ring-track" cx="36" cy="36" r="32" />
            <circle
              class="rt-card__ring-arc"
              cx="36"
              cy="36"
              r="32"
              style={`stroke-dasharray:${RING_CIRC.toFixed(1)};stroke-dashoffset:${RING_OFFSET.toFixed(1)}`}
            />
          </svg>
          <span class="rt-card__ring-value">58</span>
        </div>
        <p class="rt-card__ring-label" aria-hidden="true">AI Visibility Score</p>

        <!-- Platform badges -->
        <div class="rt-card__badges" aria-hidden="true">
          <span class="rt-badge">
            <span class="rt-badge__dot" style="background:#10A37F"></span>
            <span class="rt-badge__name">ChatGPT</span>
            <span class="rt-badge__score" style="color:#10A37F">74</span>
          </span>
          <span class="rt-badge">
            <span class="rt-badge__dot" style="background:#F59E0B"></span>
            <span class="rt-badge__name">Perplexity</span>
            <span class="rt-badge__score" style="color:#F59E0B">41</span>
          </span>
          <span class="rt-badge">
            <span class="rt-badge__dot" style="background:#0C7B82"></span>
            <span class="rt-badge__name">Claude</span>
            <span class="rt-badge__score" style="color:#0C7B82">58</span>
          </span>
        </div>

        <!-- Divider -->
        <div class="rt-card__divider" aria-hidden="true"></div>

        <!-- Recommendations preview -->
        <p class="rt-card__recs-label" aria-hidden="true">5 recommendations</p>
        <div class="rt-card__bars" aria-hidden="true">
          <span class="rt-card__bar" style="width:85%"></span>
          <span class="rt-card__bar" style="width:70%"></span>
          <span class="rt-card__bar" style="width:55%"></span>
        </div>

        <a href="/free-visibility-report/" class="rt-card__btn">
          Get your free report <span class="rt-card__btn-arrow" aria-hidden="true">&#x2197;</span>
        </a>
      </div>

      <p class="rt__caption">Example report. Your scores will vary.</p>
    </div>
  </div>
</section>

<style>
  .rt {
    background: #0C7B82;
    padding-block: 48px;
    color: #FFFFFF;
  }
  .rt__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    align-items: center;
    gap: 40px;
  }

  /* ---------- Left column (unchanged) ---------- */
  .rt__eyebrow {
    margin: 0 0 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .rt__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(26px, 1.4rem + 1.6vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .rt__lead {
    margin: 14px 0 0;
    max-width: 34rem;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    text-wrap: pretty;
  }

  /* ---------- Right column: mini report card ---------- */
  .rt-card {
    background: #0A1520;
    border: 0.5px solid #1E3A4A;
    border-radius: 14px;
    padding: 24px;
  }

  .rt-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .rt-card__kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: #64748B;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .rt-card__domain {
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: #64748B;
    white-space: nowrap;
  }

  /* Score ring */
  .rt-card__ring {
    position: relative;
    width: 72px;
    height: 72px;
    margin: 16px auto 0;
  }
  .rt-card__ring-svg {
    width: 72px;
    height: 72px;
    transform: rotate(-90deg);
  }
  .rt-card__ring-track { fill: none; stroke: #1E3A4A; stroke-width: 6; }
  .rt-card__ring-arc {
    fill: none;
    stroke: #F59E0B;
    stroke-width: 6;
    stroke-linecap: round;
  }
  .rt-card__ring-value {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    line-height: 1;
    color: #FFFFFF;
    font-variant-numeric: tabular-nums;
  }
  .rt-card__ring-label {
    margin: 6px 0 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1.3;
    color: #64748B;
  }

  /* Platform badges */
  .rt-card__badges {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }
  .rt-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: #0D1826;
    border: 0.5px solid #1E3A4A;
    border-radius: 20px;
  }
  .rt-badge__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .rt-badge__name {
    font-family: var(--font-mono);
    font-size: 9px;
    line-height: 1;
    color: #FFFFFF;
  }
  .rt-badge__score {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 11px;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  /* Divider */
  .rt-card__divider {
    margin-top: 16px;
    height: 1px;
    background: #1E3A4A;
  }

  /* Recommendations preview */
  .rt-card__recs-label {
    margin: 12px 0 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.3;
    color: #64748B;
  }
  .rt-card__bars {
    display: flex;
    flex-direction: column;
  }
  .rt-card__bar {
    height: 8px;
    margin-top: 6px;
    background: #1E3A4A;
    border-radius: 4px;
  }

  .rt-card__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 16px;
    padding: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    line-height: 1;
    color: #FFFFFF;
    background: #0C7B82;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-out);
  }
  .rt-card__btn:hover { background: #0A6970; }
  .rt-card__btn-arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .rt-card__btn:hover .rt-card__btn-arrow { transform: translate(2px, -2px); }

  .rt__caption {
    margin: 10px 0 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1.4;
    color: #64748B;
    opacity: 0.7;
  }

  @media (max-width: 48rem) {
    .rt { padding-block: 40px; }
    .rt__inner { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
