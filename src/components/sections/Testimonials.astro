---
/**
 * Testimonials.astro: six-card testimonial grid.
 *
 * Surface #F7F9FC, 96px top/bottom. 2-up grid on desktop via
 * repeat(auto-fit, minmax(300px, 1fr)) so it collapses to 1 column
 * once the container falls below ~620px. Each card uses a
 * <figure>/<blockquote>/<figcaption> structure for semantic
 * correctness; the big opening quote mark is a CSS pseudo-element.
 */

const QUOTES = [
  {
    quote: 'Excellent service and expertise for any web development and SEO requirements.',
    name: 'Rob Lancaster',
  },
  {
    quote: 'Working with Mark has been exactly the experience we were hoping for. Professional, knowledgeable, creative and proactive. We have no hesitation in recommending their services.',
    name: 'Jiffo',
  },
  {
    quote: 'The support we got from the team was fundamental in understanding how to manage the website from an SEO point of view. Our sewing school is not only at number one for our key local search terms, but has stayed there for several years.',
    name: 'Sew In Brighton Sewing School',
  },
  {
    quote: 'Tom is incredibly efficient, responsive and easy to work with. He really listens, takes the time to understand what you want and then goes above and beyond to deliver it. He has created some fantastic websites and landing pages for me and I am so pleased with the results.',
    name: 'R Savory',
  },
  {
    quote: 'Tom has been fantastic to work with. Practical, responsive, and always quick to get things sorted. His help with setting up and improving our websites has made a real difference. We have seen more traffic, more bookings, and smoother online operations overall.',
    name: 'Chloe Auger',
  },
  {
    quote: 'Once you have worked with Tom you will appreciate his honesty and depth of experience in print, video, web design, and you will trust him to look after your website because he also understands the technical bits. I have worked with Tom for years and I simply would not waste my time looking for anyone else.',
    name: 'Philip Meldrum',
  },
] as const;
---

<section class="testimonials" aria-labelledby="testimonials-title">
  <div class="container">

    <header class="testimonials__head">
      <p class="testimonials__eyebrow">What clients say</p>
      <h2 id="testimonials-title" class="testimonials__title">
        Real results from real businesses
      </h2>
    </header>

    <div class="testimonials__grid">
      {QUOTES.map((q) => (
        <figure class="testimonial">
          <blockquote class="testimonial__quote">
            <p>{q.quote}</p>
          </blockquote>
          <figcaption class="testimonial__attr">
            <div class="testimonial__name">{q.name}</div>
            </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: #F7F9FC;
    padding-block: 96px;
  }

  /* ---------- Header ---------- */
  .testimonials__head { text-align: center; }
  .testimonials__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .testimonials__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 1.6rem + 1.6vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }

  /* ---------- Grid ---------- */
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    max-width: 960px;
    margin: 48px auto 0;
  }

  /* ---------- Card ---------- */
  .testimonial {
    margin: 0;
    padding: 28px;
    background: #FFFFFF;
    border: 0.5px solid #E4E8EF;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
  }

  /* Big decorative opening quote mark */
  .testimonial::before {
    content: "\201C";
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 64px;
    line-height: 1;
    color: #E0F4F5;
    margin-bottom: 8px;
  }

  .testimonial__quote {
    margin: 0;
    flex: 1;
  }
  .testimonial__quote p {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-style: italic;
    font-size: 15px;
    line-height: 1.7;
    color: #64748B;
    text-wrap: pretty;
  }

  .testimonial__attr {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #E4E8EF;
  }
  .testimonial__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #0D1321;
  }
  .testimonial__source {
    display: block;
    margin-top: 3px;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.4;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 48rem) {
    .testimonials { padding-block: 64px; }
    .testimonials__grid { margin-top: 40px; }
  }
</style>
