---
/**
 * ServicesGrid.astro: three-card overview of what we do.
 *
 * White surface, 96px top/bottom padding, centred header, 3-up grid
 * collapsing to single column on mobile. Each card uses the
 * ServiceCard primitive with a custom icon slot.
 */
import ServiceCard from '../ui/ServiceCard.astro';

const STROKE = 'stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"';
---

<section class="services" aria-labelledby="services-title">
  <div class="container">

    <header class="services__head">
      <p class="services__eyebrow">What we do</p>
      <h2 id="services-title" class="services__title">
        Everything your site needs to be found
      </h2>
    </header>

    <div class="services__grid">

      <ServiceCard
        number="01"
        title="SEO audit"
        description="A complete technical review of your site. You get a prioritised fix list and a PageSpeed score that proves the work."
        href="/services/seo-audit/"
      >
        {/* Magnifying glass with a plus inside */}
        <svg slot="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="10" cy="10" r="6" />
          <line x1="14.5" y1="14.5" x2="20" y2="20" />
          <line x1="10" y1="7"  x2="10" y2="13" />
          <line x1="7"  y1="10" x2="13" y2="10" />
        </svg>
      </ServiceCard>

      <ServiceCard
        number="02"
        title="LLM visibility"
        description="Schema, llms.txt, entity signals, and content structured so AI systems cite you rather than your competitors."
        href="/services/llm-visibility/"
      >
        {/* Four nodes connected to a central node */}
        <svg slot="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5"  x2="12" y2="9.5" />
          <line x1="12" y1="14.5" x2="12" y2="19" />
          <line x1="5"  y1="12" x2="9.5"  y2="12" />
          <line x1="14.5" y1="12" x2="19" y2="12" />
          <circle cx="12" cy="12" r="2.5" />
          <circle cx="12" cy="3"  r="2" />
          <circle cx="12" cy="21" r="2" />
          <circle cx="3"  cy="12" r="2" />
          <circle cx="21" cy="12" r="2" />
        </svg>
      </ServiceCard>

      <ServiceCard
        number="03"
        title="Technical SEO"
        description="Indexing, site structure, Core Web Vitals, and internal linking — the engineering foundations everything else sits on."
        href="/services/technical-seo/"
      >
        {/* Stacked layers: site architecture */}
        <svg slot="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3 21 8 12 13 3 8 12 3Z" />
          <polyline points="3,12 12,17 21,12" />
          <polyline points="3,16 12,21 21,16" />
        </svg>
      </ServiceCard>

      <ServiceCard
        number="04"
        title="Visibility that compounds"
        description="Monthly monitoring, content updates, and AI search tracking so your visibility compounds over time."
        href="/services/visibility-that-compounds/"
      >
        {/* Upward polyline with a dot at the peak */}
        <svg slot="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="3,19 9,14 14,11 20,5" />
          <circle cx="20" cy="5" r="1.5" />
        </svg>
      </ServiceCard>

      <ServiceCard
        number="05"
        title="Local SEO and Google Business Profile"
        description="Google Business Profile, local citations, and location schema so you show up when nearby customers are searching."
        href="/services/local-seo/"
      >
        {/* Map pin */}
        <svg slot="icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 21s-6-5.3-6-10a6 6 0 0 1 12 0c0 4.7-6 10-6 10Z" />
          <circle cx="12" cy="11" r="2.5" />
        </svg>
      </ServiceCard>

    </div>

    <p class="services__all">
      <a href="/services/" class="services__all-link">
        See all services <span aria-hidden="true" class="services__all-arrow">&rarr;</span>
      </a>
    </p>
  </div>
</section>

<style>
  .services {
    background: #FFFFFF;
    padding-block: 96px;
  }

  /* ---------- Header ---------- */
  .services__head {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto 64px;
  }
  .services__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 16px;
  }
  .services__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(28px, 1.5rem + 1.6vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    margin: 0;
    text-wrap: balance;
  }

  /* ---------- Grid ----------
     Mobile-first: single column → 2-up → a balanced 3-then-2 pyramid
     on desktop so five cards never leave an orphan row. */
  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 40rem) {
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 64rem) {
    .services__grid { grid-template-columns: repeat(6, 1fr); }
    /* Every card spans two columns = equal 1/3 width. */
    .services__grid > :global(*) { grid-column: span 2; }
    /* Bottom row of two: offset so the pair centres under the three. */
    .services__grid > :global(:nth-child(4)) { grid-column: 2 / span 2; }
    .services__grid > :global(:nth-child(5)) { grid-column: 4 / span 2; }
  }

  /* ---------- Footer link ---------- */
  .services__all {
    margin: 48px 0 0;
    text-align: center;
  }
  .services__all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 15px;
    color: #0C7B82;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .services__all-link:hover { color: #0A6970; }
  .services__all-arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .services__all-link:hover .services__all-arrow {
    transform: translateX(3px);
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 48rem) {
    .services { padding-block: 64px; }
    .services__head { margin-bottom: 40px; }
  }
</style>
