---
/**
 * Nav.astro: primary site navigation.
 *
 * Layout: wordmark left, links centre, primary CTA right.
 * Mobile: links collapse into a <details>-driven panel (zero JS path).
 * A tiny deferred script upgrades the panel to close on outside click /
 * Esc, and locks scroll while open. Native semantics carry the page.
 */
import { SITE, NAV } from '../lib/site';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const isCurrent = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<header class="nav" role="banner">
  <div class="container nav__inner">

    <a href="/" class="nav__brand" aria-label={`${SITE.name}, home`}>
      <span class="nav__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
      </span>
      <span class="nav__wordmark">Found Everywhere</span>
    </a>

    <details class="nav__menu" id="nav-menu" open>
      <summary class="nav__toggle" aria-label="Toggle navigation">
        <span class="nav__toggle-bars" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="sr-only">Menu</span>
      </summary>

      <nav class="nav__panel" aria-label="Primary">
        <ul class="nav__links" role="list">
          {NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class="nav__link"
                aria-current={isCurrent(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="nav__cta">
          <a href="/contact" class="btn">Book an audit</a>
        </div>
      </nav>
    </details>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: color-mix(in oklab, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--color-line);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    min-height: 4.5rem;
  }

  /* ---------- Brand ---------- */
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--text-md);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .nav__mark {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-md);
    background: var(--color-accent);
    color: var(--color-accent-ink);
  }

  /* ---------- Menu (details) ---------- */
  .nav__menu { position: relative; }
  .nav__menu > summary { list-style: none; }
  .nav__menu > summary::-webkit-details-marker { display: none; }
  .nav__menu > summary::marker { content: ''; }

  /* Toggle button (mobile only) */
  .nav__toggle {
    display: none;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: var(--color-bg);
  }
  .nav__toggle-bars { display: inline-flex; flex-direction: column; gap: 4px; }
  .nav__toggle-bars span {
    display: block;
    width: 1rem;
    height: 1.5px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--duration-base) var(--ease-out),
                opacity var(--duration-fast) var(--ease-out);
  }
  .nav__menu[open] .nav__toggle-bars span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .nav__menu[open] .nav__toggle-bars span:nth-child(2) { opacity: 0; }
  .nav__menu[open] .nav__toggle-bars span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  /* Panel: desktop = inline row, mobile = full-width drawer */
  .nav__panel {
    display: flex;
    align-items: center;
    gap: var(--space-7);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .nav__links li + li { margin-top: 0; }

  .nav__link {
    position: relative;
    display: inline-block;
    padding: var(--space-2) 0;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .nav__link::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 2px;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .nav__link:hover::after,
  .nav__link[aria-current="page"]::after { transform: scaleX(1); }
  .nav__link[aria-current="page"] { color: var(--color-accent); }

  /* ---------- Mobile breakpoint ---------- */
  @media (max-width: 48rem) {
    .nav__toggle { display: inline-flex; }

    .nav__panel {
      position: absolute;
      top: calc(100% + 1px);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-5);
      padding: var(--space-6) var(--gutter);
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-line);
      box-shadow: var(--shadow-lg);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition:
        transform var(--duration-base) var(--ease-out),
        opacity   var(--duration-base) var(--ease-out);
    }
    .nav__menu[open] .nav__panel {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav__links {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      border-top: 1px solid var(--color-line);
    }
    .nav__links li {
      border-bottom: 1px solid var(--color-line);
    }
    .nav__link {
      display: block;
      padding: var(--space-4) 0;
      font-size: var(--text-md);
    }
    .nav__link::after { display: none; }

    .nav__cta .btn { width: 100%; }
  }
</style>

<script>
  /**
   * Nav <details> behaviour.
   *
   * The element is rendered `open` by default so non-JS desktop users
   * see the full nav row, and non-JS mobile users see the panel below
   * the brand row (the <summary> still toggles it).
   *
   * With JS we get the proper UX: closed-by-default on mobile, open on
   * desktop, and the panel closes on outside click / Esc / link tap.
   * Module scripts are deferred by Astro by default.
   */
  const menu = document.getElementById('nav-menu') as HTMLDetailsElement | null;
  if (menu) {
    const mq = window.matchMedia('(max-width: 48rem)');
    const isMobile = () => mq.matches;

    const syncToViewport = () => {
      if (isMobile()) {
        menu.open = false;
        document.body.style.overflow = '';
      } else {
        menu.open = true;
        document.body.style.overflow = '';
      }
    };
    // Run before paint so users never see the desktop nav flash closed.
    syncToViewport();
    mq.addEventListener('change', syncToViewport);

    const close = () => { menu.open = false; document.body.style.overflow = ''; };

    // Body scroll lock: only while open on mobile.
    menu.addEventListener('toggle', () => {
      if (menu.open && isMobile()) document.body.style.overflow = 'hidden';
      else document.body.style.overflow = '';
    });

    // Outside click: only meaningful on mobile.
    document.addEventListener('click', (e) => {
      if (!isMobile() || !menu.open) return;
      if (!menu.contains(e.target as Node)) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMobile() && menu.open) close();
    });

    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => { if (isMobile()) close(); })
    );
  }
</script>
