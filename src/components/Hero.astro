---
/**
 * Hero.astro: kinetic hero on a dark surface.
 *
 * Centred, full-width, dark `#0D1826` background. The headline is a
 * single line; directly beneath it a rotating platform logo cycles
 * through six brands on its own 2500ms timer with 300ms fade.
 *
 * The cycler is wrapped in `@media (prefers-reduced-motion: no-preference)`.
 * Under reduced motion (or no JS) the static fallback row of all six
 * logos is shown instead.
 */

/**
 * Platforms shown in the rotating logo strip below the headline.
 * `src` is loaded from /images/brands/; `name` is the alt text used
 * on the static fallback (no on-screen name in the rotator).
 */
const PLATFORMS = [
  { src: '/images/brands/chatgpt.svg',    name: 'ChatGPT' },
  { src: '/images/brands/google.svg',     name: 'Google' },
  { src: '/images/brands/copilot.svg',    name: 'Copilot' },
  { src: '/images/brands/perplexity.svg', name: 'Perplexity' },
  { src: '/images/brands/claude.svg',     name: 'Claude' },
  { src: '/images/brands/gemini.svg',     name: 'Gemini' },
] as const;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container hero__inner">

    <p class="hero__eyebrow">SEO + LLM visibility</p>

    <h1 id="hero-title" class="hero__title">Be found on</h1>

    {/* Rotating platform logo, directly under the headline. */}
    <div class="hero__platforms">
      <div class="hero__platforms-cycle" id="hero-platforms-cycle">
        <img
          class="hero__platforms-logo"
          src={PLATFORMS[0].src}
          alt={PLATFORMS[0].name}
          width="160"
          height="40"
        />
      </div>

      {/* Reduced-motion fallback: static row of all six logos. */}
      <ul class="hero__platforms-static" role="list" aria-label="Platforms we optimise for">
        {PLATFORMS.map((p) => (
          <li>
            <img src={p.src} alt={p.name} height="40" />
          </li>
        ))}
      </ul>
    </div>

    <p class="hero__lead">
      We audit and optimise your website so it ranks in Google and gets
      cited by ChatGPT, Claude, Perplexity, and Gemini. Wherever
      your customers are searching.
    </p>

    <div class="hero__cta">
      <a href="/contact" class="hero__btn hero__btn--primary">
        Get your free audit <span aria-hidden="true" class="hero__btn-arrow">&#x2197;</span>
      </a>
      <a href="/approach" class="hero__btn hero__btn--ghost">How it works</a>
    </div>

    <p class="hero__platforms-strip" aria-label="Platforms we optimise for">
      ChatGPT · Google · Copilot · Perplexity · Claude · Gemini
    </p>
  </div>
</section>

<script is:inline define:vars={{ platforms: PLATFORMS }}>
  /**
   * Platform-logo cycler. Single <img> swap.
   * Cadence: 2500ms display → 300ms fade out → swap src → 300ms fade in.
   * Bails under prefers-reduced-motion (CSS then shows the static row).
   */
  (function () {
    var cycleEl = document.getElementById('hero-platforms-cycle');
    if (!cycleEl) return;
    var img = cycleEl.querySelector('.hero__platforms-logo');
    if (!img) return;

    var motionMq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (motionMq.matches) return;

    var i = 0;
    function step() {
      img.classList.add('is-fading');
      // After fade-out, swap src and fade in.
      setTimeout(function () {
        i = (i + 1) % platforms.length;
        img.setAttribute('src', platforms[i].src);
        img.setAttribute('alt', platforms[i].name);
        img.classList.remove('is-fading');
        // 300ms fade-in + 2500ms hold, then step again.
        setTimeout(step, 300 + 2500);
      }, 300);
    }
    // Initial 2500ms hold before the first transition.
    setTimeout(step, 2500);
  })();
</script>

<style>
  /* ============================================================
     SHELL
     ============================================================ */
  .hero {
    background: #0D1826;
    color: #FFFFFF;
    padding-block: clamp(5rem, 4rem + 6vw, 9rem);
    text-align: center;
    overflow: hidden;
  }

  .hero__inner {
    display: block;
    text-align: center;
  }

  /* ============================================================
     EYEBROW
     ============================================================ */
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--space-6);
  }

  /* ============================================================
     TITLE: single line
     ============================================================ */
  .hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 52px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    margin: 0;
    text-wrap: balance;
  }

  /* ============================================================
     BODY COPY
     ============================================================ */
  .hero__lead {
    margin: 0 auto;
    max-width: 520px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.65;
    color: #94A3B8;
    text-wrap: pretty;
  }

  /* ============================================================
     CTAs
     ============================================================ */
  .hero__cta {
    margin-top: var(--space-7);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }
  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 11px 24px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    border-radius: 8px;
    border: 1px solid transparent;
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .hero__btn:active { transform: translateY(1px); }

  .hero__btn--primary {
    background: #0C7B82;
    color: #FFFFFF;
    border-color: #0C7B82;
  }
  .hero__btn--primary:hover {
    background: #0A6970;
    border-color: #0A6970;
  }
  .hero__btn-arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .hero__btn--primary:hover .hero__btn-arrow {
    transform: translate(2px, -2px);
  }

  .hero__btn--ghost {
    background: transparent;
    color: #94A3B8;
    border-color: #2D3748;
  }
  .hero__btn--ghost:hover {
    color: #FFFFFF;
    border-color: #94A3B8;
  }

  /* ============================================================
     PLATFORM ROTATOR
     A single rotating logo sits between the headline and the body
     copy. Reduced-motion users see a static row of all six.
     ============================================================ */
  .hero__platforms {
    /* 16px below the headline, 32px above the lead. */
    margin: 16px auto 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__platforms-cycle {
    display: flex;
    justify-content: center;
    align-items: center;
    /* Reserve room so swapping logos never reflows the layout. */
    min-height: 40px;
  }

  .hero__platforms-logo {
    display: block;
    height: 40px;
    width: auto;
    opacity: 0.9;
    transition: opacity 300ms ease;
  }
  .hero__platforms-logo.is-fading { opacity: 0; }

  /* Static fallback row: all six logos in a single line. */
  .hero__platforms-static {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 32px;
  }
  .hero__platforms-static img {
    display: block;
    height: 40px;
    width: auto;
    opacity: 0.9;
  }

  /* If the user prefers reduced motion, swap the rotator for the
     static row. The JS controller also bails under this query. */
  @media (prefers-reduced-motion: reduce) {
    .hero__platforms-cycle  { display: none; }
    .hero__platforms-static { display: flex; }
  }

  /* ============================================================
     PLATFORM REFERENCE STRIP
     Static dot-separated names at the very bottom of the hero.
     ============================================================ */
  .hero__platforms-strip {
    margin: 48px 0 0;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.6;
    color: #64748B;
    letter-spacing: 0.06em;
    text-align: center;
    text-wrap: balance;
  }

  /* ============================================================
     MOBILE
     ============================================================ */
  @media (max-width: 48rem) {
    .hero { padding-block: clamp(4rem, 3rem + 6vw, 6rem); }
    .hero__title { font-size: 36px; }
    .hero__lead { font-size: 16px; padding-inline: var(--space-2); }
    .hero__cta {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      max-width: 22rem;
      margin-inline: auto;
      gap: var(--space-3);
    }
    .hero__btn { justify-content: center; padding-block: 14px; }
    .hero__platforms        { margin: 12px auto 24px; }
    .hero__platforms-logo,
    .hero__platforms-static img { height: 32px; }
    .hero__platforms-static { gap: 20px; }
    .hero__platforms-strip { margin-top: 32px; font-size: 9px; }
  }
</style>
