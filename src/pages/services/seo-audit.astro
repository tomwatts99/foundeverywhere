---
/**
 * services/seo-audit.astro: detail page for the SEO audit service.
 *
 * Schema flow: FAQPage built from the same AUDIT_FAQS source rendered
 * on-page, plus a BreadcrumbList (Home > Services > this page). Both
 * flow through schemaExtras into the single <head> @graph.
 */
import Page from '../../layouts/Page.astro';
import FAQItem from '../../components/ui/FAQItem.astro';
import CTABlock from '../../components/sections/CTABlock.astro';
import { faqPageSchema, breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';

const FEATURES = [
  {
    num: '01',
    title: 'Technical health',
    body: 'Crawlability, indexing, redirects, broken links, duplicate content, and the technical foundations that search engines need to work properly. Most sites have more issues here than they realise.',
  },
  {
    num: '02',
    title: 'PageSpeed and Core Web Vitals',
    body: 'We test your site on both mobile and desktop and score every Core Web Vitals metric. Slow sites rank lower and convert worse. We tell you exactly what is causing the problem.',
  },
  {
    num: '03',
    title: 'On-page SEO',
    body: 'Title tags, meta descriptions, heading structure, keyword usage, and internal linking. We check every indexable page and flag what needs fixing.',
  },
  {
    num: '04',
    title: 'Schema and structured data',
    body: 'We audit your existing schema implementation and identify every opportunity to add structured data that helps search engines and AI systems understand your content.',
  },
  {
    num: '05',
    title: 'Mobile experience',
    body: 'More than half of all searches happen on mobile. We test your site as a mobile user and flag anything that is hurting your visibility or your conversions.',
  },
  {
    num: '06',
    title: 'AI visibility check',
    body: 'Every audit includes a test of your site across the major AI systems — ChatGPT, Perplexity, Gemini, and Copilot. You will know exactly where you stand before we start any work.',
  },
] as const;

const DELIVERABLES = [
  {
    title: 'Full audit report',
    body: 'Every issue documented, scored by impact, and explained in plain English. Not a spreadsheet. A clear document you can act on.',
  },
  {
    title: 'Prioritised fix list',
    body: 'Issues ranked by impact so you know exactly what to tackle first. Quick wins highlighted separately.',
  },
  {
    title: 'Before scores',
    body: 'PageSpeed scores, Core Web Vitals, and AI visibility baseline so you can measure improvement.',
  },
  {
    title: '30 minute walkthrough',
    body: 'We walk you through the findings on a call so nothing is left unclear.',
  },
] as const;

const AUDIT_FAQS = [
  {
    question: 'What do I need to provide?',
    answer:
      'Just your website URL and a brief description of your business and target customers. We handle everything else.',
  },
  {
    question: 'Will the audit tell me what to fix or will you fix it too?',
    answer:
      'The audit is a standalone service — you get a full report and fix list you can act on yourself or hand to a developer. If you want us to do the fixes, we can quote for that separately or move onto a retainer.',
  },
  {
    question: 'My site was built by an agency. Can you still audit it?',
    answer:
      'Yes. We audit sites built on any platform — WordPress, Webflow, Squarespace, Shopify, custom builds. The platform does not matter.',
  },
  {
    question: 'How is this different from a free SEO tool?',
    answer:
      'Free tools check a limited set of signals and give you a score. We check 40+ technical factors, test your AI visibility across five platforms, explain what every issue actually means, and tell you what to fix first. The output is actionable, not just informational.',
  },
  {
    question: 'Do you audit ecommerce sites?',
    answer:
      'Yes. Ecommerce audits cover everything in the standard audit plus product page optimisation, category structure, and schema for products and reviews.',
  },
  {
    question: 'What happens after the audit?',
    answer:
      'That is entirely up to you. Some clients take the report and act on it themselves. Others ask us to do the fixes. Others move straight onto a retainer. There is no pressure to do anything beyond the audit.',
  },
];

const pageUrl = `${SITE.url}/services/seo-audit/`;
const schemaExtras = [
  faqPageSchema(AUDIT_FAQS, pageUrl),
  breadcrumbSchema(
    [
      { name: 'Home',      item: `${SITE.url}/` },
      { name: 'Services',  item: `${SITE.url}/services/` },
      { name: 'SEO Audit', item: pageUrl },
    ],
    pageUrl,
  ),
];
---

<Page
  title="SEO Audit Service UK | Found Everywhere"
  description="A complete technical SEO audit for your website. 40+ point review, PageSpeed analysis, and a prioritised fix list in plain English. From £497."
  path="/services/seo-audit/"
  schemaExtras={schemaExtras}
  bleed
>

  <!-- ============ 1. HERO ============ -->
  <section class="sa-hero" aria-labelledby="sa-hero-title">
    <div class="container">
      <p class="sa-hero__eyebrow">SEO audit</p>
      <h1 id="sa-hero-title" class="sa-hero__title">Find out exactly what is holding your site back</h1>
      <p class="sa-hero__lead">
        We crawl your site the way Google does, score every element, and
        give you a prioritised fix list in plain English. No jargon. No
        fluff. Just clarity.
      </p>
      <div class="sa-hero__cta">
        <a href="/contact/" class="sa-btn sa-btn--primary">
          Book your audit <span aria-hidden="true" class="sa-btn__arrow">&#x2197;</span>
        </a>
        <a href="/how-it-works/" class="sa-btn sa-btn--ghost">See how it works</a>
      </div>
    </div>
  </section>

  <!-- ============ 2. TWO COLUMN ============ -->
  <section class="sa-body">
    <div class="container">
      <div class="sa-body__grid">

        <!-- LEFT COLUMN -->
        <div class="sa-content">

          <h2 class="sa-h2">What the audit covers</h2>

          <ul class="sa-features" role="list">
            {FEATURES.map((f) => (
              <li class="sa-feature">
                <span class="sa-feature__num">{f.num}</span>
                <div>
                  <h3 class="sa-feature__title">{f.title}</h3>
                  <p class="sa-feature__body">{f.body}</p>
                </div>
              </li>
            ))}
          </ul>

          <h2 class="sa-h2 sa-h2--gap">What you get</h2>

          <ul class="sa-deliverables" role="list">
            {DELIVERABLES.map((d) => (
              <li class="sa-deliverable">
                <svg class="sa-deliverable__check" aria-hidden="true" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
                <div>
                  <h3 class="sa-deliverable__title">{d.title}</h3>
                  <p class="sa-deliverable__body">{d.body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- RIGHT COLUMN -->
        <aside class="sa-card" aria-label="SEO audit summary">
          <p class="sa-card__eyebrow">Investment</p>
          <p class="sa-card__price">From £497</p>
          <p class="sa-card__turnaround">Delivered within 2 weeks</p>

          <hr class="sa-card__divider" />

          <ul class="sa-card__checks" role="list">
            <li>
              <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
              <span>40+ point technical review</span>
            </li>
            <li>
              <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
              <span>AI visibility check included</span>
            </li>
            <li>
              <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
              <span>Plain English throughout</span>
            </li>
          </ul>

          <a href="/contact/" class="sa-card__cta">
            Book your audit
            <span aria-hidden="true" class="sa-card__cta-arrow">&#x2197;</span>
          </a>

          <p class="sa-card__note">
            Not sure if you need this? Get in touch and we will tell you
            honestly.
          </p>
        </aside>

      </div>
    </div>
  </section>

  <!-- ============ 3. WHO THIS IS FOR ============ -->
  <section class="sa-who" aria-labelledby="sa-who-title">
    <div class="container">
      <p class="sa-who__eyebrow">Who this is for</p>
      <h2 id="sa-who-title" class="sa-who__title">Built for businesses that want answers, not activity</h2>
      <p class="sa-who__body">
        The SEO audit is for any business that suspects their site is
        underperforming but does not know why. It is for founders who have
        had SEO work done before and are not sure what they got. It is for
        marketing managers who need to make a case for investment. And it
        is for anyone who has never had a proper audit and wants to know
        where they actually stand.
      </p>
    </div>
  </section>

  <!-- ============ 4. FAQ ============ -->
  <section class="sa-faq" aria-labelledby="sa-faq-title">
    <div class="container">
      <p class="sa-faq__eyebrow">Common questions</p>
      <h2 id="sa-faq-title" class="sa-faq__title">What people ask about the audit</h2>
      <div class="sa-faq__list">
        {AUDIT_FAQS.map((faq) => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 5. CTA ============ -->
  <CTABlock />

</Page>

<style>
  /* ============================================================
     1. HERO
     ============================================================ */
  .sa-hero {
    background: #0D1826;
    color: #FFFFFF;
    text-align: center;
    padding-block: 96px;
  }
  .sa-hero__eyebrow {
    margin: 0 0 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .sa-hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 1.6rem + 3.6vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .sa-hero__lead {
    margin: 20px auto 0;
    max-width: 560px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.65;
    color: #94A3B8;
    text-wrap: pretty;
  }
  .sa-hero__cta {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  /* Hero buttons */
  .sa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 13px 22px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .sa-btn--primary {
    color: #FFFFFF;
    background: #0C7B82;
    border: 1px solid #0C7B82;
  }
  .sa-btn--primary:hover { background: #0A6970; border-color: #0A6970; }
  .sa-btn--ghost {
    color: #FFFFFF;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .sa-btn--ghost:hover { border-color: rgba(255, 255, 255, 0.55); }
  .sa-btn__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .sa-btn--primary:hover .sa-btn__arrow { transform: translate(2px, -2px); }

  /* ============================================================
     2. TWO-COLUMN BODY
     ============================================================ */
  .sa-body { background: #FFFFFF; padding-block: 96px; }

  .sa-body__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 64px;
    max-width: 960px;
    margin: 0 auto;
    align-items: start;
  }

  /* ---------- Left: content ---------- */
  .sa-h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 1.3rem + 1.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
  }
  .sa-h2--gap { margin-top: 64px; }

  /* Features list */
  .sa-features {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .sa-feature {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    align-items: start;
  }
  .sa-feature__num {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 13px;
    line-height: 1.5;
    color: #0C7B82;
    letter-spacing: 0.04em;
  }
  .sa-feature__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #0D1321;
  }
  .sa-feature__body {
    margin: 6px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: #64748B;
    text-wrap: pretty;
  }

  /* Deliverables list */
  .sa-deliverables {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .sa-deliverable {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: start;
  }
  .sa-deliverable__check {
    color: #0C7B82;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .sa-deliverable__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #0D1321;
  }
  .sa-deliverable__body {
    margin: 5px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.6;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ---------- Right: sticky card ---------- */
  .sa-card {
    position: sticky;
    top: calc(4.5rem + 24px);
    background: #FFFFFF;
    border: 0.5px solid #E4E8EF;
    border-radius: 16px;
    padding: 32px;
    align-self: start;
  }
  .sa-card__eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .sa-card__price {
    margin: 8px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 36px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #0C7B82;
  }
  .sa-card__turnaround {
    margin: 6px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.4;
    color: #64748B;
  }
  .sa-card__divider {
    border: 0;
    border-top: 1px solid #E4E8EF;
    margin: 20px 0;
  }
  .sa-card__checks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .sa-card__checks li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.4;
    color: #64748B;
  }
  .sa-card__checks svg { color: #0C7B82; flex-shrink: 0; }

  .sa-card__cta {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin-top: 24px;
    padding: 12px 16px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    line-height: 1;
    color: #FFFFFF;
    background: #0C7B82;
    border: 1px solid #0C7B82;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }
  .sa-card__cta:hover { background: #0A6970; border-color: #0A6970; }
  .sa-card__cta-arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .sa-card__cta:hover .sa-card__cta-arrow { transform: translate(2px, -2px); }

  .sa-card__note {
    margin: 12px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    line-height: 1.55;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============================================================
     3. WHO THIS IS FOR
     ============================================================ */
  .sa-who {
    background: #F7F9FC;
    padding-block: 96px;
    text-align: center;
  }
  .sa-who .container { max-width: 800px; }
  .sa-who__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .sa-who__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 1.3rem + 1.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }
  .sa-who__body {
    margin: 24px auto 0;
    max-width: 640px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============================================================
     4. FAQ
     ============================================================ */
  .sa-faq {
    background: #FFFFFF;
    padding-block: 96px;
  }
  .sa-faq .container { max-width: 800px; }
  .sa-faq__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .sa-faq__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 1.5rem + 1.6vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }
  .sa-faq__list {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 56rem) {
    .sa-body__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .sa-card {
      position: static;
      order: 1;
    }
  }
  @media (max-width: 48rem) {
    .sa-hero { padding-block: 72px; }
    .sa-body { padding-block: 72px; }
    .sa-who  { padding-block: 72px; }
    .sa-faq  { padding-block: 72px; }
    .sa-card { padding: 24px; }
  }
</style>
