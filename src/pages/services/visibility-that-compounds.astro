---
/**
 * services/visibility-that-compounds.astro: detail page for the
 * ongoing SEO + LLM visibility retainer.
 *
 * Schema flow: FAQPage built from the same VC_FAQS source rendered
 * on-page, plus a BreadcrumbList (Home > Services > this page). Both
 * flow through schemaExtras into the single <head> @graph.
 */
import Page from '../../layouts/Page.astro';
import FAQItem from '../../components/ui/FAQItem.astro';
import CTABlock from '../../components/sections/CTABlock.astro';
import { faqPageSchema, breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';

const FEATURES = [
  {
    num: '01',
    title: 'Technical monitoring',
    body: 'Monthly crawl of your site to catch new issues before they affect rankings. Broken links, crawl errors, indexing problems, and Core Web Vitals regressions all caught and fixed as they appear.',
  },
  {
    num: '02',
    title: 'AI visibility tracking',
    body: 'We test your brand across ChatGPT, Perplexity, Gemini, Copilot, and Claude every month. You see exactly where you appear, where you do not, and how that changes over time.',
  },
  {
    num: '03',
    title: 'Schema and structured data updates',
    body: 'Search and AI standards evolve. We keep your schema current, add new types as they become relevant, and fix any validation errors that appear.',
  },
  {
    num: '04',
    title: 'Content optimisation',
    body: 'We identify underperforming pages and improve them. Updated headings, better structured content, refreshed FAQs, and internal linking improvements that compound over time.',
  },
  {
    num: '05',
    title: 'Google Business Profile management',
    body: 'Regular GBP posts, photo updates, review monitoring, and profile optimisation. Local visibility maintained month by month.',
  },
  {
    num: '06',
    title: 'Monthly reporting',
    body: 'A clear report every month covering rankings, AI visibility, traffic trends, and work completed. No vanity metrics, no padding. Just the numbers that matter and what we did about them.',
  },
] as const;

const VC_FAQS = [
  {
    question: 'Do I need to have done an audit first?',
    answer:
      'Not necessarily, but it helps. If we have not worked together before we will do a quick review of your site before starting a retainer to make sure we know exactly what we are working with.',
  },
  {
    question: 'What is the minimum commitment?',
    answer:
      'Three months. SEO and AI visibility work takes time to show results and three months gives us enough time to do meaningful work and show you the impact.',
  },
  {
    question: 'Can I cancel after three months?',
    answer:
      'Yes. After the initial three months the retainer runs month to month with 30 days notice to cancel.',
  },
  {
    question: 'How much of my time does this require?',
    answer:
      'Very little. A monthly call to review the report and discuss priorities — typically 30 minutes. We handle everything else.',
  },
  {
    question: 'What if I just need a one-off piece of work?',
    answer:
      'The retainer is for ongoing work. If you need something specific done once, the audit or technical SEO service is a better fit. Get in touch and we will point you in the right direction.',
  },
  {
    question: 'How do I know if it is working?',
    answer:
      'Every month you get a report showing ranking movements, AI visibility scores, traffic trends, and work completed. You will always know exactly what we have done and what impact it has had.',
  },
];

const pageUrl = `${SITE.url}/services/visibility-that-compounds/`;
const schemaExtras = [
  faqPageSchema(VC_FAQS, pageUrl),
  breadcrumbSchema(
    [
      { name: 'Home',                     item: `${SITE.url}/` },
      { name: 'Services',                 item: `${SITE.url}/services/` },
      { name: 'Visibility That Compounds', item: pageUrl },
    ],
    pageUrl,
  ),
];
---

<Page
  title="Ongoing SEO and LLM Visibility Management UK | Found Everywhere"
  description="Monthly SEO and AI visibility management that compounds over time. Rankings that do not slip, AI citations that grow, and clear reporting every month."
  path="/services/visibility-that-compounds/"
  schemaExtras={schemaExtras}
  bleed
>

  <!-- ============ 1. HERO ============ -->
  <section class="vc-hero" aria-labelledby="vc-hero-title">
    <div class="container">
      <p class="vc-hero__eyebrow">Visibility that compounds</p>
      <h1 id="vc-hero-title" class="vc-hero__title">SEO and AI visibility that keeps working</h1>
      <p class="vc-hero__lead">
        Most businesses do the work once and wonder why results slip.
        Visibility is not a project. It is an ongoing process. We keep
        working after the initial build so your rankings grow and your AI
        presence compounds month by month.
      </p>
      <div class="vc-hero__cta">
        <a href="/contact/" class="vc-btn vc-btn--primary">
          Talk to us <span aria-hidden="true" class="vc-btn__arrow">&#x2197;</span>
        </a>
        <a href="/services/" class="vc-btn vc-btn--ghost">See all services</a>
      </div>
    </div>
  </section>

  <!-- ============ 2. TWO COLUMN ============ -->
  <section class="vc-body">
    <div class="container">
      <div class="vc-body__grid">

        <!-- LEFT COLUMN -->
        <div class="vc-content">

          <h2 class="vc-h2">What is included every month</h2>

          <ul class="vc-features" role="list">
            {FEATURES.map((f) => (
              <li class="vc-feature">
                <span class="vc-feature__num">{f.num}</span>
                <div>
                  <h3 class="vc-feature__title">{f.title}</h3>
                  <p class="vc-feature__body">{f.body}</p>
                </div>
              </li>
            ))}
          </ul>

          <h2 class="vc-h2 vc-h2--gap">Who this is for</h2>
          <p class="vc-prose">
            The retainer is for businesses that have solid foundations in
            place — either through our audit and fix service or existing
            work — and want to maintain and grow their visibility over
            time. It is not for businesses looking for a quick fix. It is
            for businesses that understand visibility compounds and want to
            stay ahead of the curve as search keeps changing.
          </p>
        </div>

        <!-- RIGHT COLUMN -->
        <aside class="vc-card" aria-label="Retainer summary">
          <p class="vc-card__eyebrow">Investment</p>
          <p class="vc-card__price">From £497/mo</p>
          <p class="vc-card__turnaround">Minimum 3 month engagement</p>

          <hr class="vc-card__divider" />

          <ul class="vc-card__checks" role="list">
            <li>
              <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
              <span>SEO and AI visibility included</span>
            </li>
            <li>
              <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
              <span>No lock-in after 3 months</span>
            </li>
            <li>
              <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
              <span>Clear monthly reporting</span>
            </li>
            <li>
              <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg>
              <span>Cancel with 30 days notice</span>
            </li>
          </ul>

          <a href="/contact/" class="vc-card__cta">
            Talk to us
            <span aria-hidden="true" class="vc-card__cta-arrow">&#x2197;</span>
          </a>

          <p class="vc-card__note">
            Not sure if you are ready for a retainer? Start with an audit
            and we will tell you honestly.
          </p>
        </aside>

      </div>
    </div>
  </section>

  <!-- ============ 3. WHY IT MATTERS ============ -->
  <section class="vc-why" aria-labelledby="vc-why-title">
    <div class="container">
      <p class="vc-why__eyebrow">Why it matters</p>
      <h2 id="vc-why-title" class="vc-why__title">Search does not stand still. Neither should your visibility.</h2>
      <p class="vc-why__body">
        Google updates its algorithm hundreds of times a year. AI search
        systems retrain and update constantly. Competitors keep working. A
        site that ranked well last year can slip without anyone noticing —
        until the enquiries dry up. The retainer exists because visibility
        is not something you fix once. It is something you maintain,
        improve, and defend. We do that for you so you can focus on running
        your business.
      </p>
    </div>
  </section>

  <!-- ============ 4. FAQ ============ -->
  <section class="vc-faq" aria-labelledby="vc-faq-title">
    <div class="container">
      <p class="vc-faq__eyebrow">Common questions</p>
      <h2 id="vc-faq-title" class="vc-faq__title">What people ask about the retainer</h2>
      <div class="vc-faq__list">
        {VC_FAQS.map((faq) => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 5. CTA ============ -->
  <CTABlock />

</Page>

<style>
  /* ============================================================
     1. HERO
     ============================================================ */
  .vc-hero {
    background: #0D1826;
    color: #FFFFFF;
    text-align: center;
    padding-block: 96px;
  }
  .vc-hero__eyebrow {
    margin: 0 0 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .vc-hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 1.6rem + 3.6vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .vc-hero__lead {
    margin: 20px auto 0;
    max-width: 560px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.65;
    color: #94A3B8;
    text-wrap: pretty;
  }
  .vc-hero__cta {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  /* Hero buttons */
  .vc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 13px 22px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .vc-btn--primary {
    color: #FFFFFF;
    background: #0C7B82;
    border: 1px solid #0C7B82;
  }
  .vc-btn--primary:hover { background: #0A6970; border-color: #0A6970; }
  .vc-btn--ghost {
    color: #FFFFFF;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .vc-btn--ghost:hover { border-color: rgba(255, 255, 255, 0.55); }
  .vc-btn__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .vc-btn--primary:hover .vc-btn__arrow { transform: translate(2px, -2px); }

  /* ============================================================
     2. TWO-COLUMN BODY
     ============================================================ */
  .vc-body { background: #FFFFFF; padding-block: 96px; }

  .vc-body__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 64px;
    max-width: 960px;
    margin: 0 auto;
    align-items: start;
  }

  /* ---------- Left: content ---------- */
  .vc-h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 1.3rem + 1.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
  }
  .vc-h2--gap { margin-top: 64px; }
  .vc-prose {
    margin: 16px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: #64748B;
    text-wrap: pretty;
  }

  /* Features list */
  .vc-features {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .vc-feature {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    align-items: start;
  }
  .vc-feature__num {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 13px;
    line-height: 1.5;
    color: #0C7B82;
    letter-spacing: 0.04em;
  }
  .vc-feature__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #0D1321;
  }
  .vc-feature__body {
    margin: 6px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ---------- Right: sticky card ---------- */
  .vc-card {
    position: sticky;
    top: calc(4.5rem + 24px);
    background: #FFFFFF;
    border: 0.5px solid #E4E8EF;
    border-radius: 16px;
    padding: 32px;
    align-self: start;
  }
  .vc-card__eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .vc-card__price {
    margin: 8px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 36px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #0C7B82;
  }
  .vc-card__turnaround {
    margin: 6px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.4;
    color: #64748B;
  }
  .vc-card__divider {
    border: 0;
    border-top: 1px solid #E4E8EF;
    margin: 20px 0;
  }
  .vc-card__checks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .vc-card__checks li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.4;
    color: #64748B;
  }
  .vc-card__checks svg { color: #0C7B82; flex-shrink: 0; }

  .vc-card__cta {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin-top: 24px;
    padding: 12px 16px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    line-height: 1;
    color: #FFFFFF;
    background: #0C7B82;
    border: 1px solid #0C7B82;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }
  .vc-card__cta:hover { background: #0A6970; border-color: #0A6970; }
  .vc-card__cta-arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .vc-card__cta:hover .vc-card__cta-arrow { transform: translate(2px, -2px); }

  .vc-card__note {
    margin: 12px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    line-height: 1.55;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============================================================
     3. WHY IT MATTERS
     ============================================================ */
  .vc-why {
    background: #F7F9FC;
    padding-block: 96px;
    text-align: center;
  }
  .vc-why .container { max-width: 800px; }
  .vc-why__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .vc-why__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 1.3rem + 1.4vw, 32px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }
  .vc-why__body {
    margin: 24px auto 0;
    max-width: 640px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============================================================
     4. FAQ
     ============================================================ */
  .vc-faq {
    background: #FFFFFF;
    padding-block: 96px;
  }
  .vc-faq .container { max-width: 800px; }
  .vc-faq__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .vc-faq__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 1.5rem + 1.6vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }
  .vc-faq__list {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 56rem) {
    .vc-body__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .vc-card {
      position: static;
      order: 1;
    }
  }
  @media (max-width: 48rem) {
    .vc-hero { padding-block: 72px; }
    .vc-body { padding-block: 72px; }
    .vc-why  { padding-block: 72px; }
    .vc-faq  { padding-block: 72px; }
    .vc-card { padding: 24px; }
  }
</style>
