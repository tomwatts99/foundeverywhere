---
/**
 * contact.astro — book-an-audit page.
 *
 * Dark hero band + white card holding a vanilla HTML form. The form
 * posts to a mailto: address with `text/plain` so it works without
 * a backend; replace with a real endpoint when one is wired up.
 * No JavaScript: native `required` validation only.
 */
import Page from '../layouts/Page.astro';
---

<Page
  title="Book a free audit | Found Everywhere"
  description="Book your free SEO and LLM visibility audit. No commitment — just clarity on where your site stands and what needs fixing."
  path="/contact/"
  bleed
>
  <!-- ============ HERO ============ -->
  <section class="contact-hero" aria-labelledby="contact-title">
    <div class="container">
      <p class="contact-hero__eyebrow">Get in touch</p>
      <h1 id="contact-title" class="contact-hero__title">Book your free audit</h1>
      <p class="contact-hero__lead">
        No commitment. Just clarity on where you stand and what needs fixing.
      </p>
    </div>
  </section>

  <!-- ============ FORM ============ -->
  <section class="contact-form-section">
    <div class="container">
      <form
        class="contact-card"
        action="mailto:hello@foundeverywhere.co.uk"
        method="POST"
        enctype="text/plain"
        aria-label="Audit request form"
      >
        <div class="field">
          <label class="field__label" for="contact-name">Name</label>
          <input
            class="field__input"
            type="text"
            id="contact-name"
            name="Name"
            autocomplete="name"
            required
          />
        </div>

        <div class="field">
          <label class="field__label" for="contact-email">Email</label>
          <input
            class="field__input"
            type="email"
            id="contact-email"
            name="Email"
            autocomplete="email"
            required
          />
        </div>

        <div class="field">
          <label class="field__label" for="contact-url">Website URL</label>
          <input
            class="field__input"
            type="url"
            id="contact-url"
            name="Website"
            placeholder="https://"
            autocomplete="url"
            required
          />
        </div>

        <div class="field">
          <label class="field__label" for="contact-message">Tell us about your site</label>
          <textarea
            class="field__input field__textarea"
            id="contact-message"
            name="Message"
            rows="4"
          ></textarea>
        </div>

        <button class="contact-submit" type="submit">
          Send my audit request
          <span aria-hidden="true" class="contact-submit__arrow">&#x2197;</span>
        </button>
      </form>

      <ul class="contact-trust" role="list">
        <li>
          <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 8 3.5 3.5L13 4" />
          </svg>
          <span>Free audit</span>
        </li>
        <li>
          <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 8 3.5 3.5L13 4" />
          </svg>
          <span>No commitment</span>
        </li>
        <li>
          <svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 8 3.5 3.5L13 4" />
          </svg>
          <span>Response within 24 hours</span>
        </li>
      </ul>
    </div>
  </section>
</Page>

<style>
  /* ============================================================
     HERO
     ============================================================ */
  .contact-hero {
    background: #0D1826;
    color: #FFFFFF;
    text-align: center;
    padding-block: 80px;
  }
  .contact-hero__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .contact-hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 1.6rem + 3vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .contact-hero__lead {
    margin: 16px auto 0;
    max-width: 36rem;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.6;
    color: #94A3B8;
    text-wrap: pretty;
  }

  /* ============================================================
     FORM SECTION
     ============================================================ */
  .contact-form-section {
    background: #FFFFFF;
    padding-block: 80px;
  }

  .contact-card {
    max-width: 600px;
    margin: 0 auto;
    padding: 40px;
    background: #FFFFFF;
    border: 0.5px solid #E4E8EF;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ---------- Field ---------- */
  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field__label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 13px;
    line-height: 1.4;
    color: #0D1321;
  }
  .field__input {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: #0D1321;
    background: #FFFFFF;
    border: 1px solid #E4E8EF;
    border-radius: 8px;
    transition: border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }
  .field__input::placeholder { color: #94A3B8; }
  .field__input:focus,
  .field__input:focus-visible {
    outline: none;
    border-color: #0C7B82;
    box-shadow: 0 0 0 3px rgba(12, 123, 130, 0.15);
  }
  .field__textarea {
    resize: vertical;
    min-height: calc(4 * 1.5em + 20px);
    font-family: var(--font-body);
  }

  /* ---------- Submit ---------- */
  .contact-submit {
    width: 100%;
    margin-top: 8px;
    padding: 14px 24px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    color: #FFFFFF;
    background: #0C7B82;
    border: 1px solid #0C7B82;
    border-radius: 8px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    transition: background-color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }
  .contact-submit:hover {
    background: #0A6970;
    border-color: #0A6970;
  }
  .contact-submit:active { transform: translateY(1px); }
  .contact-submit__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .contact-submit:hover .contact-submit__arrow {
    transform: translate(2px, -2px);
  }

  /* ============================================================
     TRUST ROW
     ============================================================ */
  .contact-trust {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    column-gap: 32px;
    row-gap: 12px;
    font-family: var(--font-body);
    font-size: 13px;
    color: #64748B;
  }
  .contact-trust li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .contact-trust li + li { margin-top: 0; }
  .contact-trust svg { color: #0C7B82; flex-shrink: 0; }

  /* ============================================================
     MOBILE
     ============================================================ */
  @media (max-width: 48rem) {
    .contact-hero { padding-block: 64px; }
    .contact-form-section { padding-block: 56px; }
    .contact-card { padding: 28px; }
    .contact-trust { column-gap: 20px; }
  }
</style>
