---
export const prerender = true;

/**
 * results/index.astro: results / proof page.
 *
 * Schema flow: a BreadcrumbList (Home > Results) flows through
 * schemaExtras into the single <head> @graph.
 */
import Page from '../../layouts/Page.astro';
import CTABlock from '../../components/sections/CTABlock.astro';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';

const STATS = [
  { value: '98',  label: 'Our own PageSpeed score' },
  { value: '100', label: 'Our SEO score' },
  { value: '100', label: 'Our best practices score' },
  { value: '#1',  label: 'Local rankings achieved for clients' },
] as const;

const SHOWCASE = [
  {
    sector: 'Local service business',
    title: 'From page three to position one for key local terms',
    before: [
      { metric: 'PageSpeed', value: '41' },
      { metric: 'Local ranking', value: 'Page 3' },
      { metric: 'AI visibility', value: 'Not found' },
    ],
    after: [
      { metric: 'PageSpeed', value: '94' },
      { metric: 'Local ranking', value: 'Position 1' },
      { metric: 'AI visibility', value: 'Cited by Perplexity' },
    ],
  },
  {
    sector: 'Professional services',
    title: 'PageSpeed transformed, schema implemented from scratch',
    before: [
      { metric: 'PageSpeed', value: '38' },
      { metric: 'Schema', value: 'None' },
      { metric: 'Core Web Vitals', value: 'Failed' },
    ],
    after: [
      { metric: 'PageSpeed', value: '97' },
      { metric: 'Schema', value: 'Complete' },
      { metric: 'Core Web Vitals', value: 'Passed' },
    ],
  },
  {
    sector: 'Ecommerce',
    title: 'Technical foundations rebuilt, rankings recovered',
    before: [
      { metric: 'PageSpeed', value: '52' },
      { metric: 'Indexed pages', value: '340' },
      { metric: 'Crawl errors', value: '47' },
    ],
    after: [
      { metric: 'PageSpeed', value: '91' },
      { metric: 'Indexed pages', value: '612' },
      { metric: 'Crawl errors', value: '0' },
    ],
  },
] as const;

const QUOTES = [
  { quote: 'Excellent service and expertise for any web development and SEO requirements.', name: 'Rob Lancaster' },
  { quote: 'Working with Mark has been exactly the experience we were hoping for. Professional, knowledgeable, creative and proactive. We have no hesitation in recommending their services.', name: 'Jiffo' },
  { quote: 'The support we got from the team was fundamental in understanding how to manage the website from an SEO point of view. Our sewing school is not only at number one for our key local search terms, but has stayed there for several years.', name: 'Sew In Brighton Sewing School' },
  { quote: 'Tom is incredibly efficient, responsive and easy to work with. He really listens, takes the time to understand what you want and then goes above and beyond to deliver it. He has created some fantastic websites and landing pages for me and I am so pleased with the results.', name: 'R Savory' },
  { quote: 'Tom has been fantastic to work with. Practical, responsive, and always quick to get things sorted. His help with setting up and improving our websites has made a real difference. We have seen more traffic, more bookings, and smoother online operations overall.', name: 'Chloe Auger' },
  { quote: 'Once you have worked with Tom you will appreciate his honesty and depth of experience in print, video, web design, and you will trust him to look after your website because he also understands the technical bits. I have worked with Tom for years and I simply would not waste my time looking for anyone else.', name: 'Philip Meldrum' },
] as const;

const pageUrl = `${SITE.url}/results/`;
const schemaExtras = [
  breadcrumbSchema(
    [
      { name: 'Home',    item: `${SITE.url}/` },
      { name: 'Results', item: pageUrl },
    ],
    pageUrl,
  ),
];
---

<Page
  title="Results | SEO and LLM Visibility Case Studies | Found Everywhere"
  description="Real results from real businesses. See how we have improved PageSpeed scores, Google rankings, and AI visibility for UK businesses."
  path="/results/"
  schemaExtras={schemaExtras}
  bleed
>

  <!-- ============ 1. HERO ============ -->
  <section class="res-hero" aria-labelledby="res-hero-title">
    <div class="container">
      <p class="res-hero__eyebrow">Results</p>
      <h1 id="res-hero-title" class="res-hero__title">What good looks like</h1>
      <p class="res-hero__lead">
        Numbers, screenshots, and honest accounts of what changed and why.
        No cherry-picked stats, no vague claims.
      </p>
    </div>
  </section>

  <!-- ============ 2. HEADLINE STATS ============ -->
  <section class="res-stats" aria-label="Headline results">
    <div class="container">
      <div class="res-stats__grid">
        {STATS.map((s) => (
          <div class="res-stat">
            <div class="res-stat__value">{s.value}</div>
            <div class="res-stat__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 3. BEFORE / AFTER ============ -->
  <section class="res-ba" aria-labelledby="res-ba-title">
    <div class="container">
      <p class="res-ba__eyebrow">Before and after</p>
      <h2 id="res-ba-title" class="res-ba__title">The difference proper SEO makes</h2>

      <div class="res-ba__list">
        {SHOWCASE.map((c) => (
          <article class="res-ba-card">
            <header class="res-ba-card__head">
              <span class="res-ba-card__sector">{c.sector}</span>
              <h3 class="res-ba-card__title">{c.title}</h3>
            </header>
            <div class="res-ba-card__body">
              <div class="res-ba-col">
                <p class="res-ba-col__label">Before</p>
                {c.before.map((row) => (
                  <div class="res-ba-row">
                    <span class="res-ba-row__metric">{row.metric}</span>
                    <span class="res-ba-row__value res-ba-row__value--before">{row.value}</span>
                  </div>
                ))}
              </div>
              <div class="res-ba-col">
                <p class="res-ba-col__label">After</p>
                {c.after.map((row) => (
                  <div class="res-ba-row">
                    <span class="res-ba-row__metric">{row.metric}</span>
                    <span class="res-ba-row__value res-ba-row__value--after">{row.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="res-ba__note">Results vary by site, sector, and starting point. These are real client outcomes.</p>
    </div>
  </section>

  <!-- ============ 4. TESTIMONIALS ============ -->
  <section class="res-ts" aria-labelledby="res-ts-title">
    <div class="container">
      <header class="res-ts__head">
        <p class="res-ts__eyebrow">What clients say</p>
        <h2 id="res-ts-title" class="res-ts__title">In their own words</h2>
      </header>
      <div class="res-ts__grid">
        {QUOTES.map((q) => (
          <figure class="res-quote">
            <blockquote class="res-quote__body">
              <p>{q.quote}</p>
            </blockquote>
            <figcaption class="res-quote__attr">
              <div class="res-quote__name">{q.name}</div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 5. CASE STUDIES PLACEHOLDER ============ -->
  <section class="res-cs" aria-labelledby="res-cs-title">
    <div class="container">
      <p class="res-cs__eyebrow">Case studies</p>
      <h2 id="res-cs-title" class="res-cs__title">Full case studies coming soon</h2>
      <p class="res-cs__body">
        We are documenting client projects in full - the starting point,
        the work, and the results. If you would like to speak to an
        existing client about their experience working with us, get in
        touch and we will arrange it.
      </p>
      <a href="/contact/" class="res-cs__cta">
        Get in touch <span aria-hidden="true">&#x2197;</span>
      </a>
    </div>
  </section>

  <!-- ============ 6. CTA ============ -->
  <CTABlock />

</Page>

<style>
  /* ============================================================
     1. HERO
     ============================================================ */
  .res-hero {
    background: #0D1826;
    color: #FFFFFF;
    text-align: center;
    padding-block: 96px;
  }
  .res-hero__eyebrow {
    margin: 0 0 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .res-hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 1.6rem + 3.6vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .res-hero__lead {
    margin: 20px auto 0;
    max-width: 520px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.65;
    color: #94A3B8;
    text-wrap: pretty;
  }

  /* ============================================================
     2. HEADLINE STATS
     ============================================================ */
  .res-stats { background: #FFFFFF; padding-block: 64px; }
  .res-stats .container { max-width: 960px; }
  .res-stats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }
  .res-stat {
    background: #F7F9FC;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }
  .res-stat__value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #0C7B82;
  }
  .res-stat__label {
    margin-top: 8px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.4;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============================================================
     3. BEFORE / AFTER
     ============================================================ */
  .res-ba { background: #F7F9FC; padding-block: 96px; }
  .res-ba .container { max-width: 960px; }
  .res-ba__eyebrow {
    margin: 0 0 16px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .res-ba__title {
    margin: 0;
    text-align: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 1.5rem + 1.6vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }

  .res-ba__list {
    max-width: 720px;
    margin: 48px auto 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .res-ba-card {
    background: #FFFFFF;
    border: 0.5px solid #E4E8EF;
    border-radius: 16px;
    overflow: hidden;
  }
  .res-ba-card__head {
    background: #0D1826;
    padding: 20px 24px;
  }
  .res-ba-card__sector {
    display: block;
    margin-bottom: 8px;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 10px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .res-ba-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .res-ba-card__body {
    padding: 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .res-ba-col__label {
    margin: 0 0 12px;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 9px;
    line-height: 1;
    color: #64748B;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .res-ba-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 0;
    border-top: 1px solid #F1F4F9;
  }
  .res-ba-row:first-of-type { border-top: 0; }
  .res-ba-row__metric {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.3;
    color: #64748B;
  }
  .res-ba-row__value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-align: right;
  }
  .res-ba-row__value--before { color: #EF4444; }
  .res-ba-row__value--after  { color: #0C7B82; }

  .res-ba__note {
    margin: 32px auto 0;
    max-width: 560px;
    text-align: center;
    font-style: italic;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.6;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============================================================
     4. TESTIMONIALS
     ============================================================ */
  .res-ts { background: #FFFFFF; padding-block: 96px; }
  .res-ts .container { max-width: 960px; }
  .res-ts__head { text-align: center; }
  .res-ts__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .res-ts__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 1.5rem + 1.6vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }
  .res-ts__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin: 48px auto 0;
  }
  .res-quote {
    margin: 0;
    padding: 28px;
    background: #FFFFFF;
    border: 0.5px solid #E4E8EF;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
  }
  .res-quote::before {
    content: "\201C";
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 64px;
    line-height: 1;
    color: #E0F4F5;
    margin-bottom: 8px;
  }
  .res-quote__body { margin: 0; flex: 1; }
  .res-quote__body p {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-style: italic;
    font-size: 15px;
    line-height: 1.7;
    color: #64748B;
    text-wrap: pretty;
  }
  .res-quote__attr {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #E4E8EF;
  }
  .res-quote__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #0D1321;
  }

  /* ============================================================
     5. CASE STUDIES PLACEHOLDER
     ============================================================ */
  .res-cs { background: #F7F9FC; padding-block: 96px; text-align: center; }
  .res-cs .container { max-width: 720px; }
  .res-cs__eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .res-cs__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 1.3rem + 1.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }
  .res-cs__body {
    margin: 24px auto 0;
    max-width: 560px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: #64748B;
    text-wrap: pretty;
  }
  .res-cs__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 32px;
    padding: 12px 24px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    line-height: 1;
    color: #FFFFFF;
    background: #0C7B82;
    border: 1px solid #0C7B82;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }
  .res-cs__cta:hover { background: #0A6970; border-color: #0A6970; }
  .res-cs__cta span {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .res-cs__cta:hover span { transform: translate(2px, -2px); }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 48rem) {
    .res-hero   { padding-block: 72px; }
    .res-stats  { padding-block: 48px; }
    .res-ba     { padding-block: 72px; }
    .res-ts     { padding-block: 72px; }
    .res-cs     { padding-block: 72px; }
  }
</style>
