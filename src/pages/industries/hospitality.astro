---
/**
 * industries/hospitality.astro: industry landing page for hospitality
 * businesses (restaurants, hotels, pubs, venues).
 *
 * Schema flow: FAQPage + BreadcrumbList (Home > Industries > Hospitality)
 * + a ProfessionalService node, all folded into the <head> @graph via
 * schemaExtras.
 */
import Page from '../../layouts/Page.astro';
import FAQItem from '../../components/ui/FAQItem.astro';
import CTABlock from '../../components/sections/CTABlock.astro';
import { faqPageSchema, breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';

const PROBLEM_CARDS = [
  {
    title: 'Commission on every cover',
    body: 'Platform fees compound. Every direct booking you miss is margin you hand to a third party.',
  },
  {
    title: 'No ownership of the guest relationship',
    body: 'The platform owns the guest data. You get the booking, not the relationship.',
  },
  {
    title: 'Invisible outside the platforms',
    body: 'If your Google presence is weak, guests who do not start on a platform may never find you at all.',
  },
] as const;

const STATS = [
  { value: '88%',    label: 'of consumers trust online reviews as much as personal recommendations' },
  { value: '46%',    label: 'of all Google searches have local intent' },
  { value: 'Direct', label: 'bookings have zero commission and higher lifetime value' },
] as const;

const FEATURES = [
  {
    num: '01',
    title: 'Local SEO',
    body: 'We optimise your website and local presence so you appear when someone nearby searches for what you offer. The right keywords, the right structure, the right signals - built to capture intent-driven searches before a platform does.',
  },
  {
    num: '02',
    title: 'Google Business Profile',
    body: 'Your GBP is your most powerful local asset. We optimise every element - categories, menus, photos, posts, attributes, booking links - and manage it month by month so it stays competitive and current.',
  },
  {
    num: '03',
    title: 'Review generation and management',
    body: 'Reviews drive both rankings and bookings. We implement a review generation process that reaches guests at the right moment, monitors incoming reviews across Google, TripAdvisor, and other platforms, and helps you respond effectively.',
  },
  {
    num: '04',
    title: 'Citation management',
    body: 'Consistent business information across directories, review platforms, and local listings is a core local ranking signal. We audit, fix, and build your citations so search engines find accurate information about your business everywhere it appears.',
  },
  {
    num: '05',
    title: 'AI and LLM visibility',
    body: 'When someone asks an AI tool to recommend a restaurant or hotel in your area, we make sure your business appears. Schema markup, entity signals, and structured content that gives AI systems what they need to cite you confidently.',
  },
  {
    num: '06',
    title: 'Website SEO and performance',
    body: 'A slow, poorly structured website undermines everything else. We audit and fix your technical foundations - PageSpeed, Core Web Vitals, schema, and on-page SEO - so your site supports your local visibility rather than holding it back.',
  },
] as const;

const AUDIENCE = [
  {
    title: 'Restaurants and cafes',
    body: 'Independent restaurants and cafes looking to drive more direct covers and reduce dependency on commission-based platforms.',
  },
  {
    title: 'Hotels and B&Bs',
    body: 'Hotels, boutique properties, and B&Bs wanting to grow direct bookings and reduce OTA commission costs.',
  },
  {
    title: 'Pubs and bars',
    body: 'Pubs and bars looking to dominate local search and become the default recommendation in their area.',
  },
  {
    title: 'Venues and events spaces',
    body: 'Private dining rooms, event spaces, and venues that need to appear when people are searching for somewhere to host.',
  },
] as const;

const HS_FAQS = [
  {
    question: 'Can you work alongside our existing TripAdvisor or Booking.com activity?',
    answer:
      'Yes. We are not anti-platform - they serve a purpose. We work alongside your existing activity to build the direct channel so you are less dependent on any single platform over time.',
  },
  {
    question: 'How long does it take to see results?',
    answer:
      'GBP improvements can show within weeks. Local organic rankings typically improve over two to three months. Review volume builds steadily from the first month.',
  },
  {
    question: 'Do you manage our TripAdvisor listing as well as Google?',
    answer:
      'We focus on Google Business Profile as the primary local ranking asset. We monitor TripAdvisor and other review platforms as part of the review management service but our optimisation work is focused where it has the most impact on search visibility.',
  },
  {
    question: 'Can you help us get more Google reviews?',
    answer:
      'Yes. Review generation is included in the monthly management service. We implement a process that reaches guests at the right moment and makes it easy to leave a review on the platform that matters most.',
  },
  {
    question: 'We already use a booking platform that handles our online presence. Do we still need this?',
    answer:
      'Booking platforms manage reservations. They do not optimise your Google Business Profile, build your local citations, fix your website\u2019s technical SEO, or make sure you appear in AI search. Those are separate things and they all affect how many people find you in the first place.',
  },
  {
    question: 'Do AI tools really recommend restaurants and hotels?',
    answer:
      'Increasingly yes. When someone asks ChatGPT or Perplexity to recommend somewhere to eat or stay in a specific area, those tools pull from structured data, reviews, and local signals. We make sure your business sends the right signals to appear in those recommendations.',
  },
];

const pageUrl = `${SITE.url}/industries/hospitality/`;
const localBusiness = {
  '@type': 'ProfessionalService',
  '@id': `${pageUrl}#service`,
  name: 'Found Everywhere - Hospitality SEO & LLM Visibility',
  url: pageUrl,
  parentOrganization: { '@id': `${SITE.url}/#organization` },
  areaServed: 'United Kingdom',
  serviceType: 'Local SEO and AI search visibility for hospitality businesses',
  audience: {
    '@type': 'BusinessAudience',
    name: 'Restaurants, hotels, pubs, and venues',
  },
};
const schemaExtras = [
  faqPageSchema(HS_FAQS, pageUrl),
  breadcrumbSchema(
    [
      { name: 'Home',        item: `${SITE.url}/` },
      { name: 'Industries',  item: `${SITE.url}/industries/` },
      { name: 'Hospitality', item: pageUrl },
    ],
    pageUrl,
  ),
  localBusiness,
];
---

<Page
  title="SEO and LLM Visibility for Hospitality Businesses | Found Everywhere"
  description="Local SEO, Google Business Profile management, and AI search visibility for restaurants, hotels, pubs, and venues. Stop depending on TripAdvisor and Booking.com. Start owning your own demand."
  path="/industries/hospitality/"
  schemaExtras={schemaExtras}
  bleed
>

  <!-- ============ 1. HERO ============ -->
  <section class="hs-hero" aria-labelledby="hs-hero-title">
    <div class="container">
      <p class="hs-hero__eyebrow">Hospitality</p>
      <h1 id="hs-hero-title" class="hs-hero__title">When someone searches for somewhere to eat or stay, are you there?</h1>
      <p class="hs-hero__lead">
        Most hospitality businesses are visible on TripAdvisor and
        Booking.com but almost invisible in Google search and AI tools. We
        change that. Local SEO, Google Business Profile management, and AI
        visibility so direct bookings grow and commission costs shrink.
      </p>
      <div class="hs-hero__cta">
        <a href="/contact/" class="hs-btn hs-btn--primary">
          Talk to us <span aria-hidden="true" class="hs-btn__arrow">&#x2197;</span>
        </a>
        <a href="/how-it-works/" class="hs-btn hs-btn--ghost">How it works</a>
      </div>
    </div>
  </section>

  <!-- ============ 2. THE PROBLEM ============ -->
  <section class="hs-problem" aria-labelledby="hs-problem-title">
    <div class="container">
      <div class="hs-problem__grid">
        <div class="hs-problem__copy">
          <p class="hs-eyebrow">The problem</p>
          <h2 id="hs-problem-title" class="hs-h2">Commission dependency is eating your margins</h2>
          <p class="hs-problem__body">
            TripAdvisor, Booking.com, OpenTable, DesignMyNight. Every
            platform that sends you a customer takes a cut. Some take a
            significant one. And the more dependent you become on those
            platforms, the harder it is to build a business that stands on
            its own.
          </p>
          <p class="hs-problem__body">
            The hospitality businesses doing well in direct bookings are not
            the ones with the biggest platform budgets. They are the ones
            that show up in Google when someone nearby is searching, that
            appear when someone asks an AI tool for a recommendation, and
            that have the reviews and the visibility to convert that
            interest into a booking without a middleman.
          </p>
        </div>
        <div class="hs-problem__cards">
          {PROBLEM_CARDS.map((c) => (
            <div class="hs-pcard">
              <h3 class="hs-pcard__title">{c.title}</h3>
              <p class="hs-pcard__body">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 3. THE OPPORTUNITY ============ -->
  <section class="hs-opp" aria-labelledby="hs-opp-title">
    <div class="container">
      <p class="hs-eyebrow hs-eyebrow--center">The opportunity</p>
      <h2 id="hs-opp-title" class="hs-h2 hs-h2--center">AI tools are the new word of mouth</h2>
      <p class="hs-opp__body">
        When someone visits a new city and asks ChatGPT for the best
        Italian restaurant nearby, or asks Perplexity to recommend a
        boutique hotel in the area, those tools pull from specific sources.
        They cite businesses with strong local signals, good reviews,
        proper schema markup, and consistent information across the web.
        Most hospitality businesses are invisible to them. We make sure
        yours is not.
      </p>
      <div class="hs-stats">
        {STATS.map((s) => (
          <div class="hs-stat">
            <div class="hs-stat__value">{s.value}</div>
            <div class="hs-stat__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 4. WHAT WE DO ============ -->
  <section class="hs-do" aria-labelledby="hs-do-title">
    <div class="container">
      <p class="hs-eyebrow">What we do</p>
      <h2 id="hs-do-title" class="hs-h2">Everything a hospitality business needs to own local search</h2>
      <ul class="hs-features" role="list">
        {FEATURES.map((f) => (
          <li class="hs-feature">
            <span class="hs-feature__num">{f.num}</span>
            <h3 class="hs-feature__title">{f.title}</h3>
            <p class="hs-feature__body">{f.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ 5. WHO THIS IS FOR (dark) ============ -->
  <section class="hs-who" aria-labelledby="hs-who-title">
    <div class="container">
      <p class="hs-eyebrow hs-eyebrow--center">Who this is for</p>
      <h2 id="hs-who-title" class="hs-h2 hs-h2--center hs-h2--light">Built for hospitality businesses serious about direct bookings</h2>
      <div class="hs-who__grid">
        {AUDIENCE.map((a) => (
          <article class="hs-who-card">
            <h3 class="hs-who-card__title">{a.title}</h3>
            <p class="hs-who-card__body">{a.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 6. PRICING ============ -->
  <section class="hs-pricing" aria-labelledby="hs-pricing-title">
    <div class="container">
      <p class="hs-eyebrow hs-eyebrow--center">Investment</p>
      <h2 id="hs-pricing-title" class="hs-h2 hs-h2--center">Straightforward pricing, no surprises</h2>
      <p class="hs-pricing__body">
        Hospitality visibility work is scoped as part of our ongoing
        retainer service. We start with a full local SEO and AI visibility
        audit so you know exactly where you stand, then move into monthly
        management.
      </p>

      <div class="hs-plans">
        <article class="hs-plan">
          <p class="hs-plan__eyebrow">Start here</p>
          <h3 class="hs-plan__title">Hospitality SEO audit</h3>
          <p class="hs-plan__price">From £497</p>
          <p class="hs-plan__desc">Full local SEO audit, GBP review, citation audit, AI visibility test, and prioritised fix list. Delivered within two weeks.</p>
          <ul class="hs-plan__checks" role="list">
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>Local rank tracking included</span></li>
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>GBP audit and recommendations</span></li>
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>AI visibility across 8 platforms</span></li>
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>Plain English report</span></li>
          </ul>
          <a href="/contact/" class="hs-plan__cta">Book your audit <span aria-hidden="true">&#x2197;</span></a>
        </article>

        <article class="hs-plan hs-plan--featured">
          <p class="hs-plan__eyebrow">Ongoing</p>
          <h3 class="hs-plan__title">Monthly visibility management</h3>
          <p class="hs-plan__price">From £697/mo</p>
          <p class="hs-plan__desc">Full monthly management of local SEO, GBP, citations, review generation, and AI visibility tracking. Clear monthly reporting.</p>
          <ul class="hs-plan__checks" role="list">
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>GBP management included</span></li>
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>Review generation and monitoring</span></li>
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>AI citation tracking</span></li>
            <li><svg aria-hidden="true" viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 8 3.5 3.5L13 4"/></svg><span>Monthly performance report</span></li>
          </ul>
          <a href="/contact/" class="hs-plan__cta">Talk to us <span aria-hidden="true">&#x2197;</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ 7. FAQ ============ -->
  <section class="hs-faq" aria-labelledby="hs-faq-title">
    <div class="container">
      <p class="hs-eyebrow">Common questions</p>
      <h2 id="hs-faq-title" class="hs-h2">What hospitality businesses ask us</h2>
      <div class="hs-faq__list">
        {HS_FAQS.map((faq) => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 8. CTA ============ -->
  <CTABlock
    title="Ready to own your own bookings?"
    lead="Start with a free conversation about where your business stands in local search and AI visibility."
  />

</Page>

<style>
  /* Shared section atoms */
  .hs-eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .hs-eyebrow--center { text-align: center; }
  .hs-h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 1.5rem + 1.6vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0D1321;
    text-wrap: balance;
  }
  .hs-h2--center { text-align: center; }
  .hs-h2--light { color: #FFFFFF; line-height: 1.2; }

  /* ============ 1. HERO ============ */
  .hs-hero {
    background: #0D1826;
    color: #FFFFFF;
    text-align: center;
    padding-block: 96px;
  }
  .hs-hero__eyebrow {
    margin: 0 0 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .hs-hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 1.6rem + 3.6vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    text-wrap: balance;
  }
  .hs-hero__lead {
    margin: 20px auto 0;
    max-width: 580px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.65;
    color: #94A3B8;
    text-wrap: pretty;
  }
  .hs-hero__cta {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }
  .hs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 13px 22px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .hs-btn--primary { color: #FFFFFF; background: #0C7B82; border: 1px solid #0C7B82; }
  .hs-btn--primary:hover { background: #0A6970; border-color: #0A6970; }
  .hs-btn--ghost {
    color: #FFFFFF;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .hs-btn--ghost:hover { border-color: rgba(255, 255, 255, 0.55); }
  .hs-btn__arrow {
    display: inline-block;
    transition: transform var(--duration-base) var(--ease-out);
  }
  .hs-btn--primary:hover .hs-btn__arrow { transform: translate(2px, -2px); }

  /* ============ 2. THE PROBLEM ============ */
  .hs-problem { background: #FFFFFF; padding-block: 96px; }
  .hs-problem .container { max-width: 960px; }
  .hs-problem__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 64px;
    align-items: start;
  }
  .hs-problem__body {
    margin: 16px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: #64748B;
    text-wrap: pretty;
  }
  .hs-problem__cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hs-pcard {
    background: #FFFFFF;
    border: 1px solid #E4E8EF;
    border-left: 3px solid #EF4444;
    border-radius: 10px;
    padding: 16px 20px;
  }
  .hs-pcard__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #0D1321;
  }
  .hs-pcard__body {
    margin: 6px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    line-height: 1.55;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============ 3. THE OPPORTUNITY ============ */
  .hs-opp { background: #F7F9FC; padding-block: 96px; }
  .hs-opp .container { max-width: 960px; }
  .hs-opp__body {
    margin: 24px auto 0;
    max-width: 680px;
    text-align: center;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: #64748B;
    text-wrap: pretty;
  }
  .hs-stats {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .hs-stat {
    background: #FFFFFF;
    border: 1px solid #E4E8EF;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }
  .hs-stat__value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 36px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #0C7B82;
  }
  .hs-stat__label {
    margin-top: 8px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============ 4. WHAT WE DO ============ */
  .hs-do { background: #FFFFFF; padding-block: 96px; }
  .hs-do .container { max-width: 960px; }
  .hs-features {
    list-style: none;
    padding: 0;
    margin: 48px 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }
  .hs-feature__num {
    display: block;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    line-height: 1;
    color: #0C7B82;
    letter-spacing: 0.08em;
  }
  .hs-feature__title {
    margin: 8px 0 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #0D1321;
  }
  .hs-feature__body {
    margin: 8px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: #64748B;
    text-wrap: pretty;
  }

  /* ============ 5. WHO THIS IS FOR (dark) ============ */
  .hs-who { background: #0D1826; padding-block: 96px; }
  .hs-who .container { max-width: 960px; }
  .hs-who__grid {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .hs-who-card {
    background: #0A1520;
    border: 0.5px solid #1E3A4A;
    border-radius: 16px;
    padding: 28px;
  }
  .hs-who-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #FFFFFF;
  }
  .hs-who-card__body {
    margin: 10px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.65;
    color: #94A3B8;
    text-wrap: pretty;
  }

  /* ============ 6. PRICING ============ */
  .hs-pricing { background: #F7F9FC; padding-block: 96px; }
  .hs-pricing .container { max-width: 800px; }
  .hs-pricing__body {
    margin: 24px auto 0;
    max-width: 580px;
    text-align: center;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.75;
    color: #64748B;
    text-wrap: pretty;
  }
  .hs-plans {
    margin: 48px auto 0;
    max-width: 720px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  .hs-plan {
    background: #FFFFFF;
    border: 1px solid #E4E8EF;
    border-radius: 16px;
    padding: 32px;
